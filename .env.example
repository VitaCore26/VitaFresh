# =================================================================
# VITA FRESH — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs.
# NE JAMAIS committer .env.local dans git.
# =================================================================

# --- Supabase (OBLIGATOIRE) ---
# Trouvez ces valeurs dans : Supabase Dashboard > Settings > API
# IMPORTANT : Doit correspondre à FreshLink (même instance Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici

# --- FreshLink API Backend ---
# URL de l'API FreshLink pour les appels backend
# En développement local : http://localhost:3001 ou http://localhost:3000/api
# En production : https://f-l.vercel.app/api (voir vercel.json rewrites)
NEXT_PUBLIC_API_URL=https://f-l.vercel.app/api

# --- Application ---
NEXT_PUBLIC_APP_NAME=Vita Fresh
NEXT_PUBLIC_APP_VERSION=1.0.0

# --- Site Configuration ---
NEXT_PUBLIC_SITE_URL=https://vita-fresh-gamma.vercel.app
NEXT_PUBLIC_CANONICAL_URL=https://vitafresh.vita-core.org

# --- Firebase (optionnel — analytics) ---
NEXT_PUBLIC_FIREBASE_API_KEY=votre_firebase_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=votre_firebase_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=votre_firebase_project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=votre_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=votre_app_id

# --- Vercel Edge Middleware ---
# Tokens & configuration pour le middleware Vercel
VERCEL_ENV=production
